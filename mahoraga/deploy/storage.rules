rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for app releases
    match /apps/mahoraga/{allPaths=**} {
      allow read: if true;
      allow write: if false; // deploy-only via CI
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
