{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/apps/mahoraga", "destination": "/apps/mahoraga/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(dmg|exe|AppImage)",
        "headers": [
          { "key": "Content-Disposition", "value": "attachment" },
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
